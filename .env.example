# Environment Variables for ringbudget

# Google Gemini API
GOOGLE_API_KEY=your_google_api_key_here

# Supabase Configuration
SUPABASE_URL=your_supabase_url_here
SUPABASE_PUBLISHABLE_KEY=your_supabase_key_here
